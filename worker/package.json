{
  "name": "push-az-worker",
  "version": "1.1.0",
  "private": true,
  "description": "Cloudflare Worker for push.az — VAPID Web Push + AI-generated content + cron scheduler + WebAuthn auth",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "db:init": "wrangler d1 execute push-az-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute push-az-db --local --file=./schema.sql",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "@simplewebauthn/server": "^11.0.0"
  }
}
